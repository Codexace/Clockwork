# Firebase Realtime Database credentials.
# Copy this file to ".env" (or ".env.local") for local dev and fill in real values.
# On Render, set these same keys as Environment Variables on the Static Site.
#
# Vite only exposes variables prefixed with VITE_ to the client bundle.
# These are CLIENT-SIDE Firebase config values (safe to expose publicly when
# Realtime Database security rules are configured — see README).

VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef123456
